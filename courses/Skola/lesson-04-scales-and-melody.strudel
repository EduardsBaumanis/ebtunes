//   s("bd ~ sd ~"),
//   s("hh*8").gain(0.4),
//   n("0 ~ 4 ~ 2 ~ 4 3")
//     .scale("C:minor")
//     .sound("piano")
//     .slow(1)
//     .room(0.3)
// )


