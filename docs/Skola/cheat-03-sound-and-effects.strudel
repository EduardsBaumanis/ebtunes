// ── CONTENTS ─────────────────────────────────────────────────────
//   1. Waveform synths
//   2. ADSR envelope
//   3. Filters — lpf / hpf / lpq
//   4. Reverb — room / size
//   5. Delay — delay / delaytime / delayfeedback
//   6. Dynamics & stereo — gain / pan
//   7. Saturation & vowel — distort / vowel
//   8. Parameter automation — sine.range()
//   9. Mixing principles — putting it together
//  10. The $: prefix — running multiple patterns


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 1. WAVEFORM SYNTHS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
//  WAVEFORM    HARMONICS             SOUND CHARACTER          BEST FOR
//  ─────────────────────────────────────────────────────────────────
//  sine        none (pure)           smooth, warm, pure        sub bass, soft leads
//  triangle    odd, low intensity    hollow, reedy, soft       bass lines, chiptune
//  square      odd, full intensity   hollow, buzzy, clarinety  chiptune, retro
//  sawtooth    all (richest)         bright, cutting, full     pads, bass, strings
//
// Usage:  note("c4").sound("sine")
//         note("c3*4").sound("sawtooth")

setcpm(30)

// Hear all four on the same note — same pitch, wildly different timbre
note("c3*4").sound("sine")
// note("c3*4").sound("triangle")
// note("c3*4").sound("square")
// note("c3*4").sound("sawtooth")

// --- Practical timbres built from waveforms ---
// BASS:      sawtooth + lpf(300) + gain(0.8)
// PAD:       sawtooth + attack(0.6) + release(1.5) + room(0.6) + lpf(1200)
// LEAD:      triangle + fast attack + short release + delay
// SUB BASS:  sine (no harmonics = pure low end, no mud)
// PLUCK:     triangle + attack(0.001) + decay(0.1) + sustain(0) + release(0.04)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 2. ADSR ENVELOPE
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
// ADSR shapes VOLUME over time after a note is triggered.
//
//   A = Attack   seconds to reach full volume    (0.001 = instant, 1.0 = 1s swell)
//   D = Decay    seconds to fall from peak to sustain level
//   S = Sustain  volume level while note is held  (0.0 to 1.0)
//   R = Release  seconds to fade after note ends
//
//   .attack(0.001)   → instant (percussive)      .attack(0.8) → slow swell
//   .decay(0.1)      → quick decay               .decay(1.0)  → slow decay
//   .sustain(0.0)    → no sustain (pluck feel)   .sustain(1.0) → full sustain
//   .release(0.05)   → quick cut                 .release(2.0) → long fade
//
// PRESET ENVELOPES:
//   PLUCK:   attack(0.001)  decay(0.08)  sustain(0)    release(0.04)
//   PAD:     attack(0.5)    decay(0.2)   sustain(0.7)  release(1.5)
//   ORGAN:   attack(0.005)  decay(0)     sustain(1.0)  release(0.05)
//   STRING:  attack(0.3)    decay(0.1)   sustain(0.8)  release(0.8)
//   STAB:    attack(0.005)  decay(0.15)  sustain(0.3)  release(0.1)

setcpm(30)

// --- PLUCK (banjo / guitar feel) ---
note("c4 e4 g4 e4 c4 e4 g4 b4")
  .sound("triangle")
  .attack(0.001).decay(0.1).sustain(0.0).release(0.04)

// --- PAD (slow swell) ---
// note("<[c4,g4] [ab3,eb4]>").sound("sawtooth")
//   .attack(0.6).decay(0.1).sustain(0.8).release(1.5).slow(2).lpf(1200).room(0.5)

// --- STAB (short, punchy chord) ---
// note("<[c4,e4,g4] [f3,a3,c4] [g3,b3,d4] [c4,e4,g4]>").sound("sawtooth")
//   .attack(0.005).decay(0.12).sustain(0.3).release(0.1).lpf(2000)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 3. FILTERS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
//   .lpf(hz)      Low-Pass Filter  — lets low freqs through, cuts highs
//                   50–200   = very dark / muffled / bass only
//                   300–600  = warm / telephone
//                   800–2000 = neutral to present
//                   4000+    = bright / open
//
//   .hpf(hz)      High-Pass Filter — lets highs through, cuts lows
//                   Use on hi-hats and cymbals (hpf 5000+) to remove rumble
//                   Use on pads (hpf 200) to make room for kick/bass
//
//   .lpq(amount)  Resonance at lpf cutoff — the nasal "wah" peak
//                   0 = flat filter    5 = mild    20 = pronounced    50 = extreme

setcpm(30)

// Open the filter by changing the number (100 = muffled, 5000 = bright)
note("c3*4").sound("sawtooth").lpf(600)

// --- Filter sweep by ear ---
// note("c3*4").sound("sawtooth").lpf(200)   // very dark
// note("c3*4").sound("sawtooth").lpf(800)   // mid
// note("c3*4").sound("sawtooth").lpf(3000)  // bright
// note("c3*4").sound("sawtooth").lpf(8000)  // wide open

// --- Resonant filter (lpq) — "wah" quality ---
// note("c3*4").sound("sawtooth").lpf(900).lpq(12)

// --- HPF for removing mud from hi-hats ---
// s("hh*8").hpf(6000).gain(0.4)

// --- Combined LPF + HPF = bandpass effect ---
// note("c3*4").sound("sawtooth").lpf(2000).hpf(300)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 4. REVERB — .room() / .size()
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
//   .room(amount)   reverb wet/dry mix   0 = dry (dead)  →  1 = drenched
//   .size(amount)   simulated room size  0 = closet       →  1 = cathedral
//
// REVERB GUIDE BY ELEMENT:
//   kick / bass         → 0 (dry) — reverb muddies low end
//   snare / clap        → 0.05–0.15 (slight room feel)
//   hi-hats             → 0.03–0.1 (barely there)
//   chord pads          → 0.4–0.8 (washed, spacious)
//   lead melody         → 0.2–0.5 (present but with air)
//   ambient / strings   → 0.7–0.9 (submerged in space)

setcpm(30)

// Melody — dry vs wet
note("c5 ~ eb5 ~ g4 bb4 ~ c5").sound("triangle").slow(2)
// note("c5 ~ eb5 ~ g4 bb4 ~ c5").sound("triangle").slow(2).room(0.5).size(0.6)
// note("c5 ~ eb5 ~ g4 bb4 ~ c5").sound("triangle").slow(2).room(0.85).size(0.9)

// --- Pad with reverb ---
// note("<[c4,g4] [ab3,eb4]>").sound("sawtooth")
//   .attack(0.5).release(1.2).lpf(1400).room(0.7).size(0.85).gain(0.3)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 5. DELAY — .delay() / .delaytime() / .delayfeedback()
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
//   .delay(amount)         wet/dry mix of the delay signal   0–1
//   .delaytime(seconds)    time between echoes               in fractions of cycle
//   .delayfeedback(amount) how much each echo feeds back     0–1
//                          (higher = longer, more repeats)
//
// MUSICALLY USEFUL DELAYTIMES (fractions of cycle):
//   0.125   = 32nd note
//   0.25    = 16th note (tight, rhythmic)
//   0.333   = 8th-note triplet
//   0.375   = dotted 8th (very common in pop/rock)
//   0.5     = 8th note (2 echoes per beat)
//   0.75    = dotted quarter (spacious)
//   1.0     = quarter note (slowest useful delay)

setcpm(30)

// Dotted-8th delay — classic melodic delay feel
note("c5 ~ ~ ~ g4 ~ ~ ~").sound("triangle").slow(2)
  .delay(0.5).delaytime(0.375).delayfeedback(0.3).room(0.3)

// --- 16th-note delay (rhythmic, slap) ---
// note("c5 ~ ~ g4 ~ ~ e4 ~").sound("sine").slow(2)
//   .delay(0.4).delaytime(0.25).delayfeedback(0.2)

// --- Triplet echo (3-against-2 feel) ---
// note("c5 ~ ~ ~ ~ ~ ~ ~").sound("triangle").slow(2)
//   .delay(0.5).delaytime(0.333).delayfeedback(0.4).room(0.4)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 6. DYNAMICS & STEREO — .gain() / .pan()
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
//   .gain(n)    volume multiplier    0 = silent   1 = default   2 = double
//   .pan(n)     stereo position      0 = hard left   0.5 = center   1 = hard right
//
// GAIN GUIDE BY ELEMENT:
//   kick drum        0.85–0.95  (dominant)
//   snare/clap       0.7–0.85
//   bass             0.6–0.75
//   hi-hats          0.3–0.45   (present but not harsh)
//   chord pads       0.2–0.35   (background)
//   melody           0.45–0.6   (upfront but not overpowering)
//
// PAN GUIDE:
//   kick / bass / snare → center (0.5)
//   hi-hats             → slight right (0.6–0.7)
//   chord pads          → slight left  (0.35–0.45)
//   melody              → center or slight right (0.5–0.55)

setcpm(30)

// A balanced mix — notice how gain + pan place each element
stack(
  s("bd ~ sd ~").gain(0.9),
  s("hh*8").gain(0.38).pan(0.65).hpf(5000),
  note("<c4 g3 a3 f3>").sound("sawtooth").lpf(400).gain(0.65),
  note("<[c4,g4] [g3,d4] [a3,e4] [f3,c4]>").sound("sawtooth")
    .attack(0.08).release(0.5).lpf(1800).room(0.5).gain(0.28).pan(0.42)
)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 7. SATURATION & VOWEL — .distort() / .vowel()
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
//   .distort(amount)        harmonic saturation    0–1
//                             0.05–0.15 = warmth / subtle grit
//                             0.3–0.5  = crunchy overdrive
//                             0.8–1.0  = heavy distortion
//
//   .vowel("a e i o u")    formant filter mimicking mouth shapes
//                           Each vowel resonates at different frequencies.
//                           Works best on sawtooth waves.

setcpm(30)

// Subtle distortion for warmth on a bass
note("c2*4").sound("sawtooth").lpf(600).distort(0.1)

// --- More crunch ---
// note("c2*4").sound("sawtooth").lpf(600).distort(0.4)

// --- Vowel filter — expressive, unusual ---
// note("c3*8").sound("sawtooth").vowel("<a e i o u>").gain(0.7)

// --- Vowel on a chord = talking synth effect ---
// note("[c3,g3]*4").sound("sawtooth").vowel("<a e i o>").gain(0.6)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 8. PARAMETER AUTOMATION — sine.range(lo, hi).slow(n)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
// Any parameter that takes a number can accept a SIGNAL instead.
// A signal is a continuously changing value — great for slow modulation.
//
//   sine.range(lo, hi)          → smooth sine wave oscillating between lo and hi
//   sine.range(lo, hi).slow(n)  → takes n cycles to complete one sweep
//
// You can automate:
//   .lpf(sine.range(200, 4000).slow(4))   → filter sweep over 4 bars
//   .gain(sine.range(0.3, 0.9).slow(8))   → volume pulse over 8 bars
//   .pan(sine.range(0, 1).slow(3))        → auto-pan over 3 bars
//   .room(sine.range(0, 0.8).slow(6))     → reverb grows and fades

setcpm(30)

// LPF sweeping from dark to bright over 4 cycles
note("c3*4").sound("sawtooth").lpf(sine.range(200, 4000).slow(4)).gain(0.7)

// --- Volume pulse (tremolo) ---
// note("c4*8").sound("sawtooth").gain(sine.range(0.1, 0.8).slow(2)).lpf(2000)

// --- Auto-pan sweep ---
// s("hh*16").pan(sine.range(0, 1).slow(3)).gain(0.4).hpf(5000)

// --- All three combined ---
// note("c3*4").sound("sawtooth")
//   .lpf(sine.range(300, 3000).slow(4))
//   .gain(sine.range(0.3, 0.8).slow(3))
//   .pan(sine.range(0.3, 0.7).slow(5))


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 9. MIXING PRINCIPLES — full stack example
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
// THE GOAL: no two instruments compete for the same frequency + position.
//
//   Frequency spectrum:
//     Kick (sub 60–100 Hz) → Bass (100–300 Hz) → Pads (300–2000 Hz) → Lead (1000–5000 Hz)
//   Stereo field:
//     Kick + bass → center. Hi-hats → right. Pads → left. Lead → center.
//   Reverb depth:
//     Kick + bass → dry (0). Snare → 0.1. Pads → 0.5–0.7. Lead → 0.3.

setcpm(30)

// Uncomment to hear a properly mixed track:
// stack(
//   // Kick: dry, centered, punchy
//   s("bd ~ ~ bd ~ ~ bd ~").gain(0.9),
//
//   // Snare: tiny room, centered
//   s("~ ~ sd ~ ~ ~ sd ~").gain(0.8).room(0.08),
//
//   // Hi-hat: high-passed, right, minimal reverb
//   s("hh*8").gain(0.38).hpf(6000).pan(0.65).room(0.04),
//
//   // Bass: dry, no reverb
//   note("c2 ~ eb2 f2 ~ f2 eb2 ~").sound("sawtooth")
//     .lpf(380).attack(0.005).decay(0.1).sustain(0.3).release(0.08).gain(0.65),
//
//   // Chord pad: slow attack, heavy reverb, slightly left
//   note("<[c4,eb4,g4] [ab3,c4,eb4]>").sound("sawtooth").slow(2)
//     .attack(0.5).release(1.2).lpf(1400).room(0.7).size(0.85).gain(0.28).pan(0.42),
//
//   // Lead: delay for movement, moderate reverb, center
//   note("c5 ~ eb5 ~ g4 bb4 ~ c5  ~ ~ g4 ~ f4 ~ eb4 ~").sound("triangle").slow(2)
//     .attack(0.01).release(0.28).delay(0.45).delaytime(0.375).delayfeedback(0.3)
//     .room(0.4).gain(0.52).pan(0.52)
// )


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 10. THE $: PREFIX — running multiple independent patterns
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
// In Strudel's REPL / code runner, only ONE top-level expression runs
// at a time — re-evaluating replaces the previous pattern.
//
// The $: prefix labels a pattern with a name so MULTIPLE patterns
// can run simultaneously without replacing each other.
// Each $: block is evaluated independently.
//
//   $: s("bd ~ sd ~")           // drums — keeps playing
//   $: note("c3*4").sound("sine")  // bass — added on top
//
// Each label must be unique. Use any word after $:.
//   $: stack( s("bd"), s("hh*8") )
//
// Without $: — every Ctrl+Enter REPLACES the entire output.
// With $:    — every Ctrl+Enter ADDS/UPDATES that named layer.
//
// EFFECT PARAMETER QUICK-REFERENCE TABLE:
//
//  PARAMETER        RANGE          WHAT IT DOES
//  ────────────────────────────────────────────────────────────
//  .gain(n)         0 – 2          volume
//  .pan(n)          0 – 1          stereo position
//  .lpf(hz)         20 – 20000     low-pass cutoff
//  .hpf(hz)         20 – 20000     high-pass cutoff
//  .lpq(n)          0 – 50         filter resonance
//  .room(n)         0 – 1          reverb amount
//  .size(n)         0 – 1          reverb room size
//  .delay(n)        0 – 1          delay amount
//  .delaytime(n)    seconds        echo interval
//  .delayfeedback(n) 0 – 1         echo decay
//  .attack(n)       seconds        ADSR attack
//  .decay(n)        seconds        ADSR decay
//  .sustain(n)      0 – 1          ADSR sustain level
//  .release(n)      seconds        ADSR release
//  .distort(n)      0 – 1          harmonic saturation
//  .vowel("a e i o u")  vowel name  formant filter

setcpm(30)
s("bd ~ sd ~").gain(0.85)
