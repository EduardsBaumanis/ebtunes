// Album: Amapiano — South African House Codes
// Track: 10 — log-drum-conversation
// Genre: Amapiano
// Tempo / CPM: 113 BPM (setcpm 28.25)
// Musical idea: Two log drums in call-and-response — left voice asks, right voice answers, panned hard.
// Strudel focus: Two parallel sine "log drum" patterns with complementary rhythms + .jux(rev) shading.
// Visualisation: ._punchcard({ cycles: 2 }) on BOTH log drums so the dialog is visible side-by-side.

setcpm(28.25)

stack(

  note("d1").sound("sine").attack(2).release(5).gain(0.4)
    .color("midnightblue"),

  // ── LOG DRUM 1 — the CALL (left) ─────────────────────────────
  note("<d2 a1 c2 d2>")
    .sound("sine").attack(0.001).release(0.2).shape(0.2).lpf(420)
    .struct("x ~ x ~  ~ ~ ~ ~")
    .gain(0.85).pan(0.2)
    .color("saddlebrown")
    ._punchcard({ cycles: 2 }),

  // ── LOG DRUM 2 — the RESPONSE (right) ────────────────────────
  note("<f2 d2 g2 a2>")
    .sound("sine").attack(0.001).release(0.2).shape(0.2).lpf(420)
    .struct("~ ~ ~ ~  x ~ x x")
    .gain(0.85).pan(0.8)
    .color("peru")
    ._punchcard({ cycles: 2 }),

  // ── PIANO ANSWER — single chord per 2 bars ───────────────────
  note("<[d3,f3,a3,c4] [g3,bb3,d4,f4]>")
    .sound("triangle").attack(0.005).release(0.6).lpf(2500)
    .struct("x ~ ~ ~ ~ ~ ~ ~")
    .gain(0.36).pan(0.5).room(0.55).slow(2)
    .color("gold"),

  // ── SHAKER ───────────────────────────────────────────────────
  s("hh*16").gain("0.18 0.10 0.22 0.12").hpf(7300)
    .color("yellow"),

  // ── RIM ──────────────────────────────────────────────────────
  s("~ rim ~ rim").gain(0.42).hpf(1500).room(0.2)
    .color("orange"),

  // ── KICK ─────────────────────────────────────────────────────
  s("bd ~ ~ ~ bd ~ ~ ~").gain(0.55).lpf(160).shape(0.1)
    .color("crimson")
)
