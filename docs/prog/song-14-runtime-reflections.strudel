  // ── MELODY — Ab pentatonic: Ab Bb C Eb F ─────────────────────
  note("eb5 ~ ~ ~ c5 ~ ab4 ~  ~ ~ ~ f4 ~ ~ ~ ~  ~ bb4 ~ ~ c5 ~ ~ eb5  ~ ~ ~ c5 ~ ab4 ~ ~")
    .sound("triangle")
    .attack(0.012).decay(0.42).sustain(0.21).release(0.56)
    .delay(0.3).delaytime(0.375).delayfeedback(0.2)
