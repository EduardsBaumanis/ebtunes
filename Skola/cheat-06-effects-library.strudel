// "Effects Library"
// Strudel sound design reference — 10 categories with runnable examples
//
// HOW TO USE:
// Uncomment any example block and press Ctrl+Enter to hear it.
// The full demonstration track at the bottom uses all 10 categories.
// Each category explains the WHY, not just the parameters.

// ══════════════════════════════════════════════════════════════════
// CATEGORY 1 — REVERB & SPACE
//
// Creates the illusion of physical space around a sound.
// The brain interprets reverb as room size — more = bigger space.
//
// WHERE TO USE:   pads, leads, snares, anything needing "air"
// WHERE NOT TO:   kick drums (reverb muddies low-end), tight bass
//
// .room(0–1)  wet/dry mix. 0=dry, 0.3=hall, 0.9=cathedral
// .size(0–1)  room size. 0=closet, 0.5=stage, 0.95=stone cathedral
// ══════════════════════════════════════════════════════════════════

// Drum booth — tight, controlled, just smear:
// note("c3 e3 g3").sound("piano").room(0.08).size(0.15)

// Concert hall — medium space, sounds professional:
// note("c3 e3 g3").sound("sine").room(0.35).size(0.5).attack(0.05).release(0.5)

// Cathedral — maximum space, 3-second tail:
// note("<c3 g2>").sound("sawtooth").attack(0.5).release(3).room(0.9).size(0.95)

// ══════════════════════════════════════════════════════════════════
// CATEGORY 2 — DELAY & ECHO
//
// Repeats the sound at set intervals. Most musical of all time effects.
// Locked to tempo = feels intentional. Unsynced = psychedelic.
//
// WARNING: delayfeedback > 0.9 = infinite echo = feedback wall.
//
// .delay(0–1)          wet/dry mix of delay
// .delaytime(seconds)  interval between repeats
// .delayfeedback(0–1)  number of repeats (0.4 = 3–4 echoes)
// ══════════════════════════════════════════════════════════════════

// Slapback echo (single fast repeat — rockabilly, dub):
// note("c4 ~ ~ ~ e4 ~ ~ ~").sound("sawtooth").delay(0.3).delaytime(0.12).delayfeedback(0.1)

// Trance/ambient delay (long, musical, 3–4 decaying repeats):
// note("c5 ~ ~ ~ ~ ~ ~ ~").sound("sine").delay(0.5).delaytime(0.5).delayfeedback(0.35)

// Dotted-quarter dub echo (rhythmically locked to tempo):
// note("c4 ~ e4 ~").sound("triangle").delay(0.4).delaytime(0.375).delayfeedback(0.3)

// ══════════════════════════════════════════════════════════════════
// CATEGORY 3 — FILTERS
//
// Sculpts frequency content. The most-used effect in electronic music.
// lpf = low-pass: lets bass through, cuts highs (warm, dark)
// hpf = high-pass: lets highs through, cuts bass (thin, airy)
// lpq = resonance: peaks at cutoff frequency (the acid "wah")
//
// .lpf(Hz)   cutoff: 200=very dark, 1500=mid, 8000=bright, 20000=open
// .hpf(Hz)   cutoff: 200=full, 4000=airy, 9000=only top air remains
// .lpq(0–20) resonance: 0=flat, 8=character, 14=acid squelch, 17=sing
// ══════════════════════════════════════════════════════════════════

// Classic TB-303 acid sweep — the sound that created acid house:
// note("c2 ~ eb2 ~ f2 ~ g2 ~").sound("sawtooth")
//   .lpf(sine.range(200, 4000).slow(2))   // automated sweep
//   .lpq(14)                               // high resonance = wah

// Telephone effect (narrow band = lo-fi, radio, megaphone):
// note("c3 e3 g3 c4").sound("sawtooth").lpf(2000).hpf(600)

// Hi-hat air only — strips all body, leaves only attack:
// s("hh*8").hpf(9500).gain(0.3)

// Pad filter breathe (slowly opens and closes over 8 cycles):
// note("<c3 g2>").sound("sawtooth").lpf(sine.range(400, 3000).slow(8)).sustain(1)

// ══════════════════════════════════════════════════════════════════
// CATEGORY 4 — DISTORTION & SATURATION
//
// Adds harmonic content and edge. Used on almost every element.
// Saturation = warmth you don't notice until it's gone.
// Distortion = grit you absolutely notice.
// Bit crush = digital lo-fi character, retro, raw.
//
// .distort(0–1)  soft clipping: 0.08=warmth, 0.3=grit, 0.7=fuzz
// .shape(0–1)    waveshaper overdrive: more aggressive than distort
// .crush(1–16)   bit crusher: 2=extreme lo-fi, 6=crunch, 12=subtle
// ══════════════════════════════════════════════════════════════════

// Gentle saturation (warms a sound — almost inaudible until compared):
// s("bd*4").distort(0.08).gain(0.9)

// Aggressive fuzz bass:
// note("c2 ~ e2 ~ g2 ~").sound("sawtooth").shape(0.65).lpf(2000).gain(0.7)

// 8-bit chiptune (bit crushing for lo-fi digital crunch):
// note("c4 e4 g4 b4").sound("sawtooth").crush(4)

// Industrial kick (layered saturation — distort + shape together):
// s("bd*4").distort(0.25).shape(0.2).lpf(5000)

// ══════════════════════════════════════════════════════════════════
// CATEGORY 5 — STEREO IMAGING
//
// Controls where sounds live in the left-right field.
// Wide stereo sounds huge. Mono-compatible means it won't collapse.
// Rule of thumb: kick and bass centered. Push everything else out.
//
// .pan(0–1)    0=hard left, 0.5=center, 1=hard right
// .jux(fn)     left=original, right=fn(original) — instant stereo width
// pan(sine...) autopan: sound moves left↔right over time
// ══════════════════════════════════════════════════════════════════

// Hi-hat panned right (classic drum-kit placement):
// s("hh*8").pan(0.75).gain(0.28)

// Ultra-wide stereo (jux + reverse = huge stereo image):
// note("c3 e3 g3").sound("sawtooth").room(0.4).jux(rev)

// Chorus effect (jux with very slight pitch shift = shimmer):
// note("c3").sound("sawtooth").jux(x => x.speed(1.007)).sustain(1).room(0.3)

// Autopan (oscillates left-right over 4 cycles):
// note("c4 ~ e4 ~").sound("sine").pan(sine.range(0.2, 0.8).slow(4))

// ══════════════════════════════════════════════════════════════════
// CATEGORY 6 — MODULATION
//
// Time-varying effects that create movement and prevent sounds
// from feeling static. A held pad without modulation sounds dead.
//
// .phaser(0–1)        phaser amount
// .phaserdepth(0–1)   sweep depth
// .phaserrate(Hz)     speed (0.2=slow sweep, 3=fast machine)
// .vowel("a/e/i/o/u") formant filter — gives sounds human vocal quality
// ══════════════════════════════════════════════════════════════════

// Slow phaser (Leslie speaker cabinet simulation):
// note("c3").sound("sawtooth").phaser(0.5).phaserdepth(0.8).phaserrate(0.25).sustain(1)

// Fast phaser (robotic machine modulation):
// note("c3 e3 g3").sound("sawtooth").phaser(0.7).phaserrate(3).gain(0.6)

// Vowel/talkbox (cycles through formants — alien or vocal):
// note("c3 ~ e3 ~").sound("sawtooth").vowel("<a e i o>").lpf(4000).gain(0.6)

// Tremolo (volume oscillation = amplitude modulation):
// note("c3").sound("sine").gain(sine.range(0.05, 0.75).fast(4)).sustain(1)

// ══════════════════════════════════════════════════════════════════
// CATEGORY 7 — ENVELOPES & DYNAMICS
//
// Controls the volume shape of each note over time.
// The envelope is often MORE important than the waveform choice.
// Same waveform with different envelope = completely different instrument.
//
// .attack(s)   time to reach peak: 0=click/snap, 0.01=fast, 0.5=pad swell
// .decay(s)    time from peak to sustain level
// .sustain(n)  level while key is held: 0=pluck, 0.8=held note, 1=full
// .release(s)  time to silence after note ends
// ══════════════════════════════════════════════════════════════════

// Pluck (instant attack, no sustain — guitar/piano character):
// note("c3 e3 g3 c4").sound("sawtooth").attack(0.001).decay(0.3).sustain(0).release(0.1)

// Pad (slow swell, always smooth — never harsh):
// note("<c3 g2>").sound("sawtooth").attack(0.45).sustain(0.9).release(2.5).room(0.5)

// Stab (fast attack with sustain — classic synth stab):
// note("c3 ~ e3 ~").sound("square").attack(0.005).decay(0.08).sustain(0.7).release(0.4)

// Kick envelope (tight punch — zero sustain is key):
// s("bd*4").attack(0).decay(0.12).sustain(0).release(0.04)

// ══════════════════════════════════════════════════════════════════
// CATEGORY 8 — PROBABILITY & VARIATION
//
// Removes mechanical perfection. The most human-sounding category.
// These modify WHEN notes play, not the audio signal itself.
// A pattern that varies = alive. A pattern that repeats exactly = machine.
//
// .degradeBy(0–1)  randomly skips notes (0.1=10% missing)
// .sometimes(fn)   applies fn ~50% of cycles
// .often(fn)       applies fn ~75% of cycles
// .rarely(fn)      applies fn ~12.5% of cycles
// .every(n, fn)    applies fn every nth cycle (predictable variation)
// ══════════════════════════════════════════════════════════════════

// Human hi-hat (randomly drops ~15% of hits):
// s("hh*16").degradeBy(0.15).gain(0.25).hpf(9000)

// Euclidean kick — 3 hits in 8 steps (mathematical clave):
// s("bd").euclid(3, 8).gain(0.9)

// Every 4 cycles the snare goes double-time (fill simulation):
// s("~ sd ~ sd").every(4, x => x.fast(2)).gain(0.75)

// Occasional grit burst on bass (variation without repetition):
// note("c2 ~ e2 ~").sound("sawtooth").sometimes(x => x.distort(0.5))

// ══════════════════════════════════════════════════════════════════
// CATEGORY 9 — PITCH & TIME
//
// Controls what notes play and how they relate in time.
// .scale() is the most powerful feature for melodic music.
// Every note in a scale automatically sounds "right" together.
//
// .note(name)   specific note: c4, fs3, bb2, eb5...
// .n(degree)    scale degree from root (0=root, 7=octave)
// .scale("...")  C:minor, F:major, D:dorian, Bb:mixolydian...
// .speed(n)     2=octave up, 0.5=octave down, -1=reverse
// .fast/.slow   speed up or slow down the pattern
// ══════════════════════════════════════════════════════════════════

// Minor pentatonic melody (every note works — safe for improvisation):
// n("0 3 5 7 10 7 5 3").scale("A:minor").sound("sine").attack(0.01).release(0.2)

// Two-octave spiral arp (ascending then descending — trance signature):
// n("0 2 3 5 7 8 10 12 10 8 7 5 3 2").scale("C:minor").sound("sawtooth")
//   .lpf(sine.range(2000,6000).slow(3)).lpq(4).attack(0.001).release(0.06)

// Reverse playback (plays sample backwards):
// s("rave").speed(-1).gain(0.7)

// Automated pitch (sine wave choosing notes from a range):
// note(sine.range(36, 72).slow(4).round()).sound("sine").gain(0.5)

// ══════════════════════════════════════════════════════════════════
// CATEGORY 10 — LAYERING & ARCHITECTURE
//
// Combining sounds into complex textures. This is arrangement.
// A good layer adds something that isn't there without it.
// A bad layer just makes things louder and muddier.
//
// stack(a, b, c)   plays all simultaneously
// .off(t, fn)      plays a delayed shadow copy of the pattern
// .jux(fn)         left=original, right=transformed — instant width
// .chunk(n, fn)    applies fn to a rotating nth chunk of the pattern
// ══════════════════════════════════════════════════════════════════

// Ghost notes (delayed shadow at reduced volume — sounds like space):
// s("sd ~ ~ sd").off(1/8, x => x.gain(0.18).hpf(3000))

// Stereo 303 (reversed right channel = massive stereo width):
// note("c2 ~ eb2 ~ f2").sound("sawtooth")
//   .lpf(sine.range(200,3000).slow(2)).lpq(12).jux(rev)

// Chunk targeting (filter opens on rotating chunk of 16ths):
// s("hh*16").chunk(4, x => x.hpf(8000).gain(0.4)).gain(0.22)

// ──────────────────────────────────────────────────────────────────
// FULL DEMONSTRATION — All 10 categories active simultaneously.
// Every effect from above is in use. Press Ctrl+Enter to run.
// ──────────────────────────────────────────────────────────────────

stack(
  // CAT 4 distortion + CAT 3 filter on kick:
  s("bd*4").distort(0.15).shape(0.2).lpf(5000).gain(0.92),

  // CAT 1 reverb + CAT 8 probability on snare:
  s("~ sd ~ sd").room(0.2).size(0.3).gain(0.76)
    .sometimes(x => x.shape(0.3)),

  // CAT 5 stereo + CAT 8 degradeBy + CAT 3 hpf on hats:
  s("hh*16").hpf(9500).degradeBy(0.12)
    .jux(x => x.hpf(11000).gain(0.7))
    .pan(sine.range(0.4, 0.65).slow(5)).gain(0.22),

  // CAT 9 scale + CAT 3 acid filter + CAT 4 saturation:
  n("0 2 3 5 7 5 3 2").scale("C:minor").sound("sawtooth")
    .lpf(sine.range(300, 3500).slow(2.5)).lpq(10).shape(0.3)
    .attack(0.001).decay(0.14).sustain(0).release(0.06)
    .gain(0.82).slow(2),

  // CAT 1 reverb + CAT 5 jux + CAT 7 pad envelope + CAT 6 vowel:
  note("<[c3,eb3,g3] [ab2,c3,eb3]>").sound("sawtooth")
    .attack(0.3).sustain(0.85).release(2.0)
    .lpf(sine.range(600, 2500).slow(6))
    .room(0.65).size(0.8)
    .jux(rev)
    .vowel("<a e>")
    .gain(0.24).slow(2),

  // CAT 2 delay + CAT 7 envelope + CAT 10 ghost layer:
  note("c5 ~ ~ ~ eb5 ~ ~ ~").sound("sine")
    .attack(0.02).decay(0.3).sustain(0.4).release(0.9)
    .delay(0.4).delaytime(0.5).delayfeedback(0.3)
    .gain(0.5).slow(2)
    .off(1/8, x => x.gain(0.15).hpf(2000))
)
