// Example Strudel pattern — press Ctrl+Enter to play, Ctrl+. to stop

$: stack(
  // Kick, snare, open hi-hat
  s("bd ~ sd ~"),
  s("~ ~ ~ oh"),

  // Closed hi-hats on every 8th
  s("hh*8").gain(0.5),

  // Bass line
  note("c2 ~ eb2 f2")
    .sound("sawtooth")
    .lpf(400)
    .gain(0.7),

  // Melody
  note("c4 eb4 g4 bb4 g4 eb4 c4 ~")
    .sound("piano")
    .slow(2)
    .room(0.4)
    .gain(0.6)
)
