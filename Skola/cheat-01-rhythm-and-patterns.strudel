// ╔══════════════════════════════════════════════════════════════╗
// ║  STRUDEL CHEAT SHEET 1 — RHYTHM & PATTERNS                  ║
// ║  How to structure time, write rhythms, and transform patterns ║
// ╚══════════════════════════════════════════════════════════════╝
//
// Ctrl+Enter  → evaluate & play the uncommented example
// Ctrl+.      → stop all sound
//
// ── CONTENTS ─────────────────────────────────────────────────────
//   1. Tempo
//   2. Mini-notation operators  (8 symbols)
//   3. stack() and cat()
//   4. Euclidean rhythms
//   5. Temporal scaling — slow() / fast()
//   6. Pattern variation — every() / sometimes() / often() / rarely()
//   7. Note randomness  — degradeBy() / rev() / late()
//   8. Sample bank quick-reference


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 1. TEMPO
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
//   setcpm(n)  — cycles per minute. 1 cycle = 1 bar.
//   BPM (4/4) = setcpm × 4 ÷ 2   (setcpm(30) ≈ 60 BPM in 4/4)
//
//   setcpm(20)   → ~60 BPM   slow / ambient
//   setcpm(30)   → ~90 BPM   medium / pop
//   setcpm(45)   → ~135 BPM  fast / techno
//   setcpm(64)   → ~128 BPM  club / house
//   setcpm(80)   → ~160 BPM  drum & bass

setcpm(30)
s("bd ~ sd ~")

// Change the number and re-evaluate — tempo shifts instantly.
// setcpm(20)
// s("bd ~ sd ~")


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 2. MINI-NOTATION — the 8 operators
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
// A pattern string splits the cycle into equal slices.
// Every symbol below modifies how that slicing works.
//
//  SYMBOL   MEANING                           EXAMPLE
//  ───────────────────────────────────────────────────────────────
//  (space)  separate events (equal slices)    "a b c d"
//  ~        rest — silence for that slot      "a ~ b ~"
//  *n       repeat n times within this slot   "a*4"  or  "a b*2 c"
//  /n       play once every n cycles          "a/2"  (plays on cycle 1, 3, 5…)
//  [a b c]  subdivision — fit a b c into ONE slot   "a [b c] a"
//  <a b c>  alternate — rotate each cycle     "<a b c>"
//  !n       replicate (same as *n for list)   "a!3 b" = "a a a b"
//  ?        random — 50% chance of playing    "a? b a?"
//  x:n      sample variation n of bank x     "hh:3"  (4th hi-hat sample)

setcpm(30)

// --- Rest vs sound ---
s("bd ~ sd ~")                       // kick, rest, snare, rest

// --- *n : repeat within slot ---
// s("bd*4")                         // four kicks per cycle (quarter notes)
// s("bd*8")                         // eight kicks per cycle (8th notes)
// s("bd ~ sd*2 ~")                  // snare hits twice in its slot

// --- /n : slow recurrence ---
// s("oh/2")                         // open hat on cycle 1, 3, 5…
// s("bd/4")                         // kick only on every 4th cycle

// --- [subdivision] : fit multiple events in one slot ---
// s("bd [sd sd] bd sd")             // two snares crammed into one slot = 16th-note snare
// s("bd [hh hh hh] bd sd")          // triplet feel inside beat 2

// --- <alternation> : different value each cycle ---
// s("bd ~ <sd cp rim> ~")           // cycle 1=snare, cycle 2=clap, cycle 3=rimshot
// s("<bd lt ht> ~ sd ~")            // kick varies cycle to cycle

// --- !n : replicate ---
// s("bd!3 sd")                      // same as "bd bd bd sd"

// --- ? : random gate (50% chance) ---
// s("hh? hh hh? hh hh? hh hh? hh") // hi-hats with random mutes

// --- x:n : sample variations ---
// s("bd:0 bd:1 bd:2 bd:3")         // four different kick samples in sequence
// s("hh:0 hh:2 hh:4 hh:6")        // alternate hi-hat flavors

// --- Combining operators ---
// s("[bd bd] ~ <sd [sd sd]> ~")    // subdivision + alternation together


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 3. stack() AND cat()
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
//   stack(a, b, c)   →  plays a, b, c SIMULTANEOUSLY (layered)
//   cat(a, b, c)     →  plays a on cycle 1, b on cycle 2, c on cycle 3,
//                        then loops. One pattern per bar.

setcpm(30)

// --- stack: layered drum kit ---
stack(
  s("bd ~ sd ~"),
  s("hh*8").gain(0.4),
  s("~ ~ ~ oh")
)

// --- cat: different bar each cycle ---
// cat(
//   s("bd ~ sd ~"),                     // bar 1: simple
//   s("bd [bd bd] sd ~"),               // bar 2: syncopated kick
//   s("bd ~ sd hh ~ sd ~"),             // bar 3: busier
//   s("bd ~ sd ~").rev()                // bar 4: reversed
// )

// --- cat + stack: arrangement building ---
// stack(
//   // Bass always plays
//   note("c2*4").sound("sine").gain(0.8),
//
//   // Drums enter gradually bar by bar
//   cat(
//     s("~"),                            // bar 1: nothing
//     s("bd*4"),                         // bar 2: kick enters
//     stack(s("bd*4"), s("hh*8")),       // bar 3: hat enters
//     stack(s("bd*4"), s("hh*8"), s("~ ~ sd ~"))  // bar 4: snare enters
//   )
// )


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 4. EUCLIDEAN RHYTHMS — .euclid(hits, steps, offset)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
// Distributes N hits as evenly as possible across K steps.
// Produces rhythms found in African, Latin, and Middle Eastern music.
//
//   .euclid(hits, steps)          → E(hits, steps)
//   .euclid(hits, steps, offset)  → rotate starting position
//
//   E(2, 3)   = [x . x]              simple waltz pulse
//   E(3, 8)   = [x . . x . . x .]   tresillo (Latin clave)
//   E(5, 8)   = [x . x x . x x .]   bossa nova clave
//   E(4, 16)  = [x . . . x . . . x . . . x . . .]  straight 4/4
//   E(7, 16)  = complex — organic, "alive" feel
//   E(11, 16) = very dense — fast jazz hi-hat feel
//   E(9, 16)  = half-time swing feel

setcpm(30)
s("bd").euclid(3, 8)

// s("bd").euclid(5, 8)               // bossa nova kick
// s("hh").euclid(9, 16).gain(0.4)    // syncopated hi-hat

// --- Rotate with offset ---
// stack(
//   s("bd").euclid(3, 8),            // starts on step 0
//   s("sd").euclid(3, 8, 2)          // starts on step 2 — different feel
// )

// --- Interlocking Euclidean layers ---
// stack(
//   s("bd").euclid(4, 16).gain(0.95),
//   s("sd").euclid(3, 16).gain(0.8),
//   s("hh").euclid(9, 16).gain(0.38),
//   s("oh").euclid(2, 16).gain(0.55)
// )


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 5. TEMPORAL SCALING — slow() / fast()
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
//   .slow(n)   →  stretch pattern across n cycles (each note n× longer)
//   .fast(n)   →  compress pattern into 1/n of a cycle (n× faster)
//
//   "a b c d"         → 4 quarter notes per cycle
//   "a b c d".slow(2) → 4 half notes (fills 2 cycles)
//   "a b c d".fast(2) → 4 eighth notes (fills half a cycle, repeats)
//
// KEY USES:
//   note("c2 eb2 g2 bb2  ab2 c3").slow(4)  → 6 notes across 4 cycles
//   s("bd*4").fast(2)                       → 8 kicks per cycle (doubletime)
//   note("<C G Am F>").slow(2)              → chord lasts 2 bars each

setcpm(30)

// slow(2): 4 notes now span 2 cycles (half notes)
note("c4 e4 g4 b4").sound("piano").slow(2)

// s("bd sd hh sd").fast(2)             // double-time drums
// note("c4 d4 e4 f4 g4").sound("piano").slow(4)  // very slow scale

// --- Practical: bass line across 4 bars ---
// note("c2 eb2 g2 bb2  ab2 c3 eb3 g3  eb2 g2 bb2 d3  bb2 d3 f3 ab3")
//   .sound("sawtooth").lpf(300).slow(4)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 6. PATTERN VARIATION — every() / sometimes() / often() / rarely()
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
// These apply a FUNCTION to a pattern, either on a schedule or at random.
//
//   .every(n, fn)      apply fn every n cycles   (deterministic)
//   .sometimes(fn)     apply fn ~50% of cycles   (random)
//   .often(fn)         apply fn ~75% of cycles   (random)
//   .rarely(fn)        apply fn ~25% of cycles   (random)
//
// Common functions to pass in:
//   x => x.rev()        reverse the pattern
//   x => x.fast(2)      double-speed
//   x => x.slow(2)      half-speed
//   x => x.gain(0)      silences it entirely
//   x => x.hpf(2000)    thin it out

setcpm(30)

// Every 4 cycles the kick pattern reverses
s("bd ~ sd hh ~ sd ~").every(4, x => x.rev())

// s("bd sd hh sd").every(3, x => x.fast(2))       // double-time every 3rd bar
// s("hh*8").sometimes(x => x.fast(2)).gain(0.4)   // random 2× bursts
// s("cp*4").rarely(x => x.rev())                  // rarely flips
// note("c4 e4 g4").sound("piano").often(x => x.slow(2))  // often stretches


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 7. RANDOMNESS & GLITCH — degradeBy() / rev() / late()
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
//   .degradeBy(p)   randomly drop notes. p = 0 (never) → 1 (always)
//   .rev()          reverse the order of events in a cycle
//   .late(t)        delay events by t (0–1, fraction of cycle)
//   .early(t)       shift events earlier by t
//
//   .degradeBy(0.2)  most notes play, occasional gaps → lo-fi feel
//   .degradeBy(0.7)  mostly gaps → sparse breakdown texture

setcpm(30)

// Slightly degraded drums — "lo-fi recorded" feel
stack(
  s("bd ~ sd ~").degradeBy(0.15),
  s("hh*8").degradeBy(0.3).gain(0.4)
)

// --- Full breakdown: drums almost gone, pad stays ---
// stack(
//   s("bd ~ sd ~").degradeBy(0.75),
//   note("<[c4,eb4,g4] [ab3,c4,eb4]>").sound("sawtooth")
//     .attack(0.5).release(1.0).room(0.8).gain(0.4)
// )

// --- .rev() on melody: palindrome phrase ---
// note("c4 d4 e4 g4 a4").sound("piano").every(2, x => x.rev()).slow(2)

// --- .late() to push a hi-hat slightly behind the beat (swing) ---
// s("hh*8").late(0.02).gain(0.4)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 8. SAMPLE BANK QUICK-REFERENCE
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
// DRUMS  (all support :n variation index)
//   bd   bass drum / kick       bd:0  bd:1  bd:2 …
//   sd   snare drum             sd:0  sd:1 …
//   hh   hi-hat (closed)        hh:0  hh:1 …
//   oh   hi-hat (open)          oh:0  oh:1 …
//   cp   clap                   cp:0 …
//   rim  rimshot                rim:0 …
//   lt   low tom                lt:0 …
//   ht   high tom               ht:0 …
//
// PLAY ALL DRUM SOUNDS:
// s("<bd sd hh oh cp rim lt ht>")
//
// MELODIC SAMPLES
//   piano  →  acoustic piano sample
//
// MELODIC SYNTHS (use with note() or n())
//   sine       square      triangle     sawtooth
//   (see cheat-03 for full sound design reference)
//
// POLYRHYTHM EXAMPLE — different lengths looping independently:
// stack(
//   s("bd sd bd"),          // 3-step pattern
//   s("hh hh hh hh")        // 4-step pattern — drifts and realigns every 12 steps
// )
